# LLM provider: openai or anthropic.
LLM_PROVIDER=openai

# Runtime environment. Set to production in deployed stacks.
APP_ENV=local

# Provider API key. For OpenRouter, use an OpenAI-compatible key.
LLM_API_KEY=change-me

# Model identifier. For OpenRouter, this can be any supported model slug.
LLM_MODEL=gpt-4o-mini

# Optional OpenAI-compatible base URL.
LLM_BASE_URL=https://openrouter.ai/api/v1

# Redis connection string for queues and rate limiting.
REDIS_URL=redis://redis:6379/0

# PostgreSQL connection string in production. SQLite fallback is supported locally.
DATABASE_URL=sqlite+aiosqlite:///./fair_llm_backend.db

# Salt used for SHA-256 hashing of sensitive fields.
SALT=replace-with-a-long-random-secret

# Raw-log retention period in days.
RETENTION_DAYS=30

# Chat endpoint rate limit per minute.
RATE_LIMIT_RPM=60

# Comma-separated CORS allowlist.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JSON map of fairness gap thresholds.
FAIRNESS_THRESHOLDS={"toxicity_gap":0.15,"stereotype_gap":0.15,"refusal_gap":0.20}

# LLM timeout and retry controls.
LLM_TIMEOUT_SECONDS=10
LLM_RETRIES=3

# Keep strict validation enabled to fail fast on incomplete production secrets.
STRICT_ENV_VALIDATION=true
